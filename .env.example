# Database
MONGO_USER=aethera
MONGO_PASS=<random-32-char-hex>
MONGO_PORT=27017

# JWT
JWT_SECRET=<random-64-char-hex>
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
JWT_ISSUER=aethera

# App
NEXT_PUBLIC_APP_NAME=Aethera
NODE_ENV=production
APP_PORT=3000
APP_MEM_LIMIT=1g

# Docker orchestration
AETHERA_DATA_DIR=/home/.aethera/run
AETHERA_BACKUP_DIR=/home/.aethera/backup
AETHERA_WORLD_UPLOAD_DIR=/home/.aethera/world_upload
AETHERA_MINECRAFT_IMAGE=itzg/minecraft-server
MONGO_MEM_LIMIT=512m

# Discord (OPTIONAL — leave empty to disable)
DISCORD_BOT_TOKEN=
DISCORD_APP_ID=
DISCORD_PUBLIC_KEY=

# First-run admin (used by seed script OR setup wizard)
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@localhost.com
ADMIN_PASSWORD=admin

# Module system (OPTIONAL — leave empty to disable module registry)
MODULE_REGISTRY_URL=https://document.pruefert.it/shares/69ce3cc6a03cf4913af9d565

# CurseForge API (OPTIONAL — required for CurseForge pack support)
CURSEFORGE_API_KEY=
