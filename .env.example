# Database
MONGODB_URI=mongodb://localhost:27017/aethera

# JWT
JWT_SECRET=<random-64-char-hex>
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
JWT_ISSUER=aethera

# App
NEXT_PUBLIC_APP_NAME=Aethera
NODE_ENV=development

# Mail (OPTIONAL — leave empty to disable)
MAIL_SMTP_HOST=
MAIL_SMTP_PORT=587
MAIL_SMTP_USERNAME=
MAIL_SMTP_PASSWORD=
MAIL_SMTP_SENDER=
MAIL_SMTP_TLS=true
MAIL_SMTP_AUTH=true

# First-run admin (used by seed script OR setup wizard)
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@localhost
ADMIN_PASSWORD=
